{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": [
      {
        "RouteId": "serviceRoute",
        "ClusterId": "serviceCluster",
        "Match": {
          "Path": "/weatherforecast",
          "Methods": [
            "GET"
          ]
        },
        "Transforms": [
          {
            "RequestHeader": "X-Internal-Key",
            "Set": "dev-internal-key-6d4f1e92-8c9a-4b7e-9f3d-5a2c1b8e0f4a"
          }
        ]
      }
    ],
    "Clusters": {
      "serviceCluster": {
        "Destinations": {
          "default": {
            "Address": "http://localhost:5112"
          }
        }
      }
    }
  }
}
